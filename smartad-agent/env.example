# ===== DeepSeek API =====
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 标准模型（指令解析/策略生成）
DEEPSEEK_MODEL=deepseek-chat
# 轻量模型（路由判断/意图分类，低成本）
DEEPSEEK_MODEL_LIGHT=deepseek-chat
# 旗舰模型（反思/复杂规划，高精度）
DEEPSEEK_MODEL_HEAVY=deepseek-reasoner

# ===== Java后端地址 =====
SMARTAD_SERVER_URL=http://localhost:8080
AI_TOKEN=smartad-ai-internal-token-2024

# ===== 轮询间隔（秒） =====
POLL_INTERVAL=5

# ===== FastAPI服务端口 =====
PORT=8001

# ===== 日志级别 =====
LOG_LEVEL=INFO

# ===== 缓存 TTL（秒）=====
CACHE_TTL_CROWD=300       # 人群画像缓存 5 分钟
CACHE_TTL_HISTORY=600     # 历史数据缓存 10 分钟
CACHE_TTL_REPORT=180      # 报表缓存 3 分钟

# ===== 护栏阈值 =====
GUARDRAIL_MAX_BUDGET=100000   # 最大日预算（元）
GUARDRAIL_MIN_BUDGET=100
GUARDRAIL_MAX_BID=10000       # 最大出价（分）
GUARDRAIL_MIN_BID=10
GUARDRAIL_HIGH_RISK_BUDGET=5000
GUARDRAIL_HIGH_RISK_BID=5000  # 50元=5000分

# ===== 反思最大迭代次数 =====
REFLECT_MAX_ITERATIONS=2
