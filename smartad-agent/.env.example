# SmartAD AI Agent 配置文件（开发环境）
# 复制此文件为 .env 并填入真实值

# ===== DeepSeek API =====
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ===== Java后端地址 =====
SMARTAD_SERVER_URL=http://localhost:8080
AI_TOKEN=smartad-ai-internal-token-2024

# ===== 轮询间隔（秒） =====
POLL_INTERVAL=5

# ===== FastAPI服务端口 =====
PORT=8001

# ===== 日志级别 =====
LOG_LEVEL=INFO
